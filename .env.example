# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (Gmail)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Admin Configuration
ADMIN_API_SECRET=generate-secure-random-secret
ADMIN_EMAILS=admin@yobbu.co,admin2@yobbu.co

# Environment
NODE_ENV=development
API_PORT=3001

# Development Only
DEV_SKIP_SMS=false
ALLOWED_ORIGINS=https://yobbu.vercel.app,https://yobbu.com,http://localhost:5173

# IMPORTANT: Copy this file to .env and fill in real values
# NEVER commit .env to version control
